# Jenkins base URL, without a trailing slash preferred.
JENKINS_URL=https://jenkins.example.com

# Use a Jenkins API token, not your login password.
JENKINS_USER=release-bot
JENKINS_API_TOKEN=replace-with-api-token

# Copy config/allowed_jobs.example.yml to config/allowed_jobs.yml and edit it.
JENKINS_ALLOWED_JOBS_FILE=config/allowed_jobs.yml
JENKINS_RELEASE_TASKS_FILE=.jenkins_release_tasks.jsonl

# Optional runtime settings.
JENKINS_REQUEST_TIMEOUT_SECONDS=30
JENKINS_VERIFY_SSL=true
MCP_HTTP_HOST=127.0.0.1
MCP_HTTP_PORT=8000

# Optional MCP HTTP Bearer token.
# Required if you expose this server beyond 127.0.0.1.
MCP_BEARER_TOKEN=replace-with-a-random-long-token

# Optional QQ Mail SMTP notification settings.
# Use a QQ Mail SMTP authorization code, not your QQ login password.
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_USERNAME=your-qq-email@qq.com
SMTP_PASSWORD=replace-with-qq-mail-smtp-auth-code
SMTP_FROM=your-qq-email@qq.com
SMTP_TO=receiver@example.com
SMTP_USE_SSL=true
