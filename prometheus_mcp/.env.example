PROMETHEUS_BASE_URL=http://prometheus.example.com:9090
PROMETHEUS_TIMEOUT_SECONDS=20
PROMETHEUS_MAX_RANGE_SECONDS=604800
PROMETHEUS_MAX_RANGE_POINTS=11000

MCP_TRANSPORT=stdio
MCP_HOST=127.0.0.1
MCP_PORT=8000
MCP_PATH=/mcp

# Optional. Required only when streamable-http mode should enforce Authorization: Bearer <token>.
# Do not commit real tokens.
MCP_AUTH_TOKEN=change-me

# Optional. Leave empty unless your MCP client requires explicit OAuth metadata URLs.
MCP_AUTH_ISSUER_URL=
MCP_AUTH_RESOURCE_URL=
